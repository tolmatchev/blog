---
type Props = {
  skills: string[];
};

const { skills } = Astro.props;
---

<div class="flex flex-col gap-y-2 md:flex-row md:gap-x-5 md:gap-y-0">
  <div class="flex flex-row flex-wrap gap-x-2 gap-y-2 md:w-4/5 mb-1 ml-1">
    {
      skills.map((skill: string) => (
        <button
          class="group inline-flex items-center gap-x-1 rounded-[7px] border px-2 py-1 text-sm text-muted-foreground transition-colors
  bg-gray-200 text-gray-800 border-gray-300
  hover:bg-gray-300
  dark:bg-gray-800 dark:text-gray-200 dark:border-gray-700
  dark:hover:bg-gray-700"
        >
           <p class="">{skill}</p>
        </button>
      ))
    }
  </div>
</div>
