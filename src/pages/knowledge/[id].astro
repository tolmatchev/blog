---
import { getCollection } from "astro:content";
import BaseDetail from "../../layouts/BaseDetail.astro";
import { PAGES } from "../../config";

if (PAGES.knowledge.isActive === false) {
    return Astro.redirect("/404");
}

export async function getStaticPaths() {
    if (PAGES.knowledge.isActive === false) return [];
    const knowledge = await getCollection("knowledge");
    return knowledge.map((talk: any) => ({
        params: { id: talk.id },
        props: { talk },
    }));
}

const { id } = Astro.params;
---

<BaseDetail collection="knowledge" id={id} />
