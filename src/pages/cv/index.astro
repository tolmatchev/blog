---
import { getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Timeline from "../../components/ui/Timeline.astro";
import Skill from "../../components/layout/Skill.astro";
import { PAGES } from "../../config";

if (PAGES.cv.isActive === false) {
    return Astro.redirect("/404");
}

const cvEntry = await getEntry("cv", "cv");
if (!cvEntry) {
    throw new Error(
        "CV content not found. Please ensure src/content/cv.md exists.",
    );
}

const { Content } = await render(cvEntry);
const { name, title, experience = [], education = [] } = cvEntry.data;
const languages = ['Html', 'JavaScript', 'CSS', 'Shell']
const frontend = ['TypeScript', 'Vite', 'Webpack', 'Astro']
const backend = ['Vercel', 'Waline']
---

<BaseLayout title={PAGES.cv.title}>
    <header class="page-header">
        <h1 class="page-title">{PAGES.cv.title}</h1>
        <p class="page-subtitle">{PAGES.cv.subtitle}</p>
    </header>

    <div class="container-narrow">
        {
            experience.length > 0 && (
                <section class="section">
                    <h2 class="section-title border-b border-border pb-2">
                        Опыт работы
                    </h2>
                    <Timeline items={experience.map(exp => ({
                        title: exp.role,
                        subtitle: exp.institution,
                        period: exp.period,
                        desc: exp.desc
                    }))} />
                </section>
            )
        }

        <div class="prose max-w-none">
            <Content />
        </div>

        <div>
            <Skill title='Languages' skills={languages} />
            <Skill title='Frontend' skills={frontend} />
            <Skill title='Backend' skills={backend} />
        </div>

        {
            education.length > 0 && (
                <section class="section">
                    <h2 class="section-title border-b border-border pb-2">
                        Образование
                    </h2>
                    <Timeline items={education.map(edu => ({
                        title: edu.degree,
                        subtitle: edu.institution,
                        period: edu.period,
                        description: edu.description,
                        thesis: edu.thesis
                    }))} />
                </section>
            )
        }

    </div>
</BaseLayout>

